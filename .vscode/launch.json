{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch AiAgentLab.Api",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/AiAgentLab.Api/bin/Debug/net9.0/AiAgentLab.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/AiAgentLab.Api",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "stopAtEntry": false,
      "console": "integratedTerminal"
    }
  ]
}